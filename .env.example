# Frontend (Vite)
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://127.0.0.1:5000
VITE_GOOGLE_CLIENT_ID=
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=common
VITE_FACEBOOK_APP_ID=
VITE_OAUTH_REDIRECT=http://localhost:5173

# Backend API
API_HOST=0.0.0.0
API_PORT=5000
API_PREFIX=/api/v1
CORS_ORIGINS=https://your-frontend-domain.com

# Auth and security
ADMIN_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=
ALLOW_SOCIAL_PROFILE_ONLY=false
EXPOSE_RESET_DEBUG_URL=false
APP_NAME=Aerovanta
APP_BASE_URL=https://app.aerovanta.com
EMAIL_PROVIDER=resend
RESET_EMAIL_FROM=security@aerovanta.com
RESET_EMAIL_REPLY_TO=
RESEND_API_KEY=
FORCE_HTTPS=true
TRUST_PROXY=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_NAME=vv_session
CSRF_COOKIE_NAME=vv_csrf

# Rate limits
RATE_LIMIT_BACKEND=memory
# Set true only for single-instance deployments. Keep false if you use multiple API replicas.
ALLOW_IN_MEMORY_RATE_LIMITER=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=25
LLM_RATE_LIMIT_WINDOW_MS=60000
LLM_RATE_LIMIT_MAX=30

# Request limits and password controls
MAX_JSON_BODY_BYTES=1048576
MAX_UPLOAD_BYTES=8388608
PASSWORD_ITERATIONS=210000
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
RESET_TOKEN_MINUTES=15
DEFAULT_SESSION_HOURS=8
REMEMBER_SESSION_DAYS=30

# Optional HTTPS keypair (recommended behind reverse proxy in production)
TLS_KEY_PATH=
TLS_CERT_PATH=

# Optional AI provider (server-side only, never expose to frontend)
# Provider options: gemini | openai | auto
AI_PROVIDER=gemini
AI_PROVIDER_FALLBACK=true

# Gemini (recommended for diagnosis)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=25000
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=18000
OPENAI_MAX_OUTPUT_TOKENS=1400
